<mujoco model="pose_sampling_poc">
  <option timestep="0.01" gravity="0 0 -9.81"/>

  <asset>
    <texture name="table_tex" type="2d" builtin="checker"
             rgb1="0.65 0.65 0.65" rgb2="0.75 0.75 0.75"
             width="64" height="64"/>
    <material name="table_mat" texture="table_tex"/>

    <material name="object_mat" rgba="1.0 0.45 0.1 1"/>
    <material name="shelf_mat" rgba="0.45 0.32 0.22 1"/>
    <material name="container_mat" rgba="0.1 0.35 0.9 0.45"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1"/>
    <camera name="overview" pos="0 -1.7 1.1" xyaxes="1 0 0 0 0.55 0.83"/>
    
    <site name="sample_center"
      pos="0 0 0.01"
      size="0.015"
      rgba="1 0 0 1"/>
    
    <!-- Table -->
    <geom name="table"
          type="box"
          pos="0 0 -0.025"
          size="0.75 0.55 0.025"
          material="table_mat"/>

    <!-- Shelf: placed at the back of the table -->
    <body name="shelf" pos="0 0.32 0">
      <!-- bottom board -->
      <geom name="shelf_bottom"
            type="box"
            pos="0 0 0.08"
            size="0.35 0.05 0.025"
            material="shelf_mat"/>

      <!-- top board -->
      <geom name="shelf_top"
            type="box"
            pos="0 0 0.32"
            size="0.35 0.05 0.025"
            material="shelf_mat"/>

      <!-- left side -->
      <geom name="shelf_left"
            type="box"
            pos="-0.35 0 0.20"
            size="0.025 0.05 0.14"
            material="shelf_mat"/>

      <!-- right side -->
      <geom name="shelf_right"
            type="box"
            pos="0.35 0 0.20"
            size="0.025 0.05 0.14"
            material="shelf_mat"/>

      <!-- back wall -->
      <geom name="shelf_back"
            type="box"
            pos="0 0.04 0.20"
            size="0.35 0.025 0.14"
            material="shelf_mat"/>
    </body>

    <!-- Open container/bin on right side of table -->
    <body name="container" pos="0.38 -0.12 0">
      <geom name="container_floor"
            type="box"
            pos="0 0 0.015"
            size="0.16 0.13 0.015"
            material="container_mat"/>

      <geom name="container_left_wall"
            type="box"
            pos="-0.16 0 0.08"
            size="0.015 0.13 0.08"
            material="container_mat"/>

      <geom name="container_right_wall"
            type="box"
            pos="0.16 0 0.08"
            size="0.015 0.13 0.08"
            material="container_mat"/>

      <geom name="container_front_wall"
            type="box"
            pos="0 -0.13 0.08"
            size="0.16 0.015 0.08"
            material="container_mat"/>

      <geom name="container_back_wall"
            type="box"
            pos="0 0.13 0.08"
            size="0.16 0.015 0.08"
            material="container_mat"/>
    </body>

    <!-- Manipulable rectangular object -->
    <body name="tracked_object" pos="-0.25 -0.15 0.035">
      <freejoint/>
      <geom name="tracked_object_geom"
            type="box"
            size="0.10 0.035 0.035"
            mass="0.2"
            friction="0.8 0.02 0.001"
            material="object_mat"/>
    </body>

    <!-- World axes -->
    <site name="world_origin" pos="0 0 0" size="0.01" rgba="1 1 1 1"/>
    <geom name="world_x_axis" type="capsule" fromto="0 0 0 0.15 0 0" size="0.003" rgba="1 0 0 1"/>
    <geom name="world_y_axis" type="capsule" fromto="0 0 0 0 0.15 0" size="0.003" rgba="0 1 0 1"/>
    <geom name="world_z_axis" type="capsule" fromto="0 0 0 0 0 0.15" size="0.003" rgba="0 0 1 1"/>
  </worldbody>
</mujoco>